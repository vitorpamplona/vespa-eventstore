# One live Nostr event per document (docid = event id) — the unit of the
# store and the recall surface for NIP-50 filters.
#
# The NIP-01 fields are stored LOSSLESSLY so the complete signed event can be
# reconstructed and served back on a REQ: the signature is over the canonical
# serialization of these exact values, so clients can re-verify what we serve.
# `tags` keeps the exact JSON array; `tag_index` is the derived, queryable form
# ("<letter>:<value>", single-letter tag names only — the space NIP-01 filters
# can address) and is NOT lossless. Do not reconstruct events from tag_index.
#
# SEARCH is per-kind: the store's extractors populate kind-specific fields
# (kind 0 fills the Brainstorm profile group; other kinds fill the generic
# tiers). The groups are LARGELY disjoint per kind, so every scoring function
# zeroes out on docs of the other kinds — one rank profile serves a mixed
# kinds filter with a plain SUM, no kind dispatch, and each doc is ranked by
# its own kind's equations weighted by the observer's web of trust imported
# from the `reputation` parent document. A kind MAY also fill a profile ROLE
# column when it carries that data (an app handler fills the whole profile
# group; a repo/podcast/stream fills `website`); the composites combine the
# groups with max()/SUM, so that deliberate overlap stays well-defined.
#
# Profile fields + equations ported VERBATIM from Brainstorm's
# brainstorm-k8s charts/brainstorm/vespa-app doc.sd (2026-07; operator-
# provided) — the §12 multiplicative-trust default and all sort alternates —
# with two mechanical changes: the trust tensors are IMPORTED from the
# reputation parent (author_influence_scores / author_follower_counts) instead of
# living on the doc, and the generic tier group extends each composite so
# non-profile kinds ride the same profiles. Query side:
# brainstorm_server app/core/vespa.py + vespa_query.py.
schema event {

    document event {

        # The exact-match filter attributes (id/pubkey/owner/tag_index) share two
        # settings beyond fast-search:
        #  - `match: cased`. Vespa string attributes match UNCASED by default,
        #    which silently diverged from NIP-01/SQLite semantics (tag values and
        #    hex compare by exact bytes; SQLite's tag_hash is case-sensitive):
        #    a stored `t:MixedCase` matched a `#t:["mixedcase"]` filter. Cased
        #    matching restores byte equality — and agrees with the in-memory
        #    reference and the SQLite store, which were always case-sensitive.
        #    (Query-side hex is normalized to lowercase by the client, matching
        #    the lowercase hex both stores hold.)
        #  - `dictionary: hash` (requires cased). These fields are only ever
        #    equality/`in`-matched — never range- or prefix-scanned — so the
        #    default B-tree dictionary buys nothing; a hash dictionary makes
        #    each term lookup O(1) instead of O(log #unique-terms). Measured
        #    noise-level at a 30k corpus (B-tree depth is tiny); the headroom is
        #    for real corpora, where unique terms grow with every event (each id
        #    is unique). A/B'd against the B-tree default and `rank: filter`
        #    (rejected: no read win, slower feeds) — see benchmark/README.md.
        field id type string {
            indexing: attribute | summary
            attribute: fast-search
            match { cased }
            dictionary { hash }
        }

        field pubkey type string {
            indexing: attribute | summary
            attribute: fast-search
            match { cased }
            dictionary { hash }
        }

        field created_at type long {
            indexing: attribute | summary
            attribute: fast-search
        }

        field kind type int {
            indexing: attribute | summary
            attribute: fast-search
        }

        # The event's exact tag array as JSON text. Summary-only: reconstruction,
        # never matching.
        field tags type string {
            indexing: summary
        }

        # Derived "<letter>:<value>" pairs for #x filter recall.
        field tag_index type array<string> {
            indexing: attribute | summary
            attribute: fast-search
            match { cased }
            dictionary { hash }
        }

        # Exact event content — reconstruction only. Search never runs against
        # raw content; searchable kinds contribute curated text to the fields
        # below instead (a kind-0's content is a JSON blob).
        field content type string {
            indexing: summary
        }

        field sig type string {
            indexing: summary
        }

        # The pubkey Nostr semantics key off: the gift-wrap recipient for kind
        # 1059, else the author. Deletion and vanish enforcement match on this
        # (SQLite's pubkey_owner_hash).
        field owner type string {
            indexing: attribute | summary
            attribute: fast-search
            match { cased }
            dictionary { hash }
        }

        # NIP-40: derived from the expiration tag at feed time, so the expiry
        # sweep AND the never-serve-expired query guard are single range
        # clauses. Always written — Long.MAX_VALUE means "never expires" (an
        # absent numeric attribute would read as 0 and break the guard).
        field expires_at type long {
            indexing: attribute | summary
            attribute: fast-search
        }

        # Reference to the author's ranking state (the global `reputation`
        # parent). Written on every doc as "id:reputation:reputation::<pubkey>";
        # the imported tensors below are what let ANY kind rank by the
        # observer's trust in its author.
        field author_ref type reference<reputation> {
            indexing: attribute
        }

        # ---- per-kind search fields (populated by the store's extractors) ----

        # kind 0 — the Brainstorm profile group. Field roles from
        # vespa_query.py: primary = name/display_name/nip05/lud16,
        # affiliation = about/website. Per NIP-24 the deprecated `username`
        # folds into `name` at extraction.
        field name type string {
            indexing: index | summary
            index: enable-bm25
            # Proper-noun field: disable stemming so "Daniels" isn't conflated
            # with "daniel" (Brainstorm §10 typo deep-dive).
            stemming: none
        }

        field display_name type string {
            indexing: index | summary
            index: enable-bm25
            stemming: none
        }

        field about type string {
            indexing: index | summary
            index: enable-bm25
        }

        field nip05 type string {
            indexing: index | summary
            index: enable-bm25
        }

        field lud16 type string {
            indexing: index | summary
            index: enable-bm25
        }

        field website type string {
            indexing: index | summary
            index: enable-bm25
        }

        # every other searchable kind — the generic tiers. What lands where is
        # the extractor's per-kind decision (docs/v2-sync-proposal.md):
        #   primary    kind 1: subject tag   30023: title
        #   secondary  kind 1: t-tags        30023: summary + t-tags
        #   tertiary   kind 1: content       30023: content
        field search_primary type string {
            indexing: index | summary
            index: enable-bm25
            stemming: none
        }

        field search_secondary type string {
            indexing: index | summary
            index: enable-bm25
        }

        field search_text type string {
            indexing: index | summary
            index: enable-bm25
        }

        # Place names, filled systemically from any kind's `location` tags
        # (classifieds, calendar events, pictures/videos). Free-text recall only;
        # geohash-proximity is a separate future column (docs/location-search-column.md).
        field search_location type string {
            indexing: index | summary
            index: enable-bm25
        }
    }

    import field author_ref.influence_scores as author_influence_scores {}
    import field author_ref.follower_counts as author_follower_counts {}

    # ---- derived trigram views (recall safety-net + tie-breaker) ----

    field name_gram type string {
        indexing: input name | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    field display_name_gram type string {
        indexing: input display_name | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    field about_gram type string {
        indexing: input about | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    field pubkey_gram type string {
        indexing: input pubkey | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    field search_primary_gram type string {
        indexing: input search_primary | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    # Discriminative (AND-matched) trigram net for the secondary tier — the same
    # typo-recall safety net `about` has (about_gram), extended to every kind's
    # summary/description so a misspelled query still recalls them.
    field search_secondary_gram type string {
        indexing: input search_secondary | index
        index: enable-bm25
        match {
            gram
            gram-size: 3
        }
    }

    fieldset default {
        fields: name, display_name, about, nip05, lud16, website, search_primary, search_secondary, search_text, search_location
    }

    fieldset grams {
        fields: name_gram, display_name_gram, pubkey_gram
    }

    # -----------------------------------------------------------------------
    # PURE-TEXT base profile — Brainstorm's text_relevance, verbatim, plus the
    # tier extension for non-profile kinds. Trust is NOT blended into
    # relevance(); the trust-sorted profiles below inherit everything here.
    # -----------------------------------------------------------------------
    rank-profile text_relevance {

        inputs {
            query(user_q) tensor<float>(user{})
            query(w_gram) double: 5.0
            query(w_display_name) double: 0.2
            query(w_about) double: 0.1
            query(w_about_bonus) double: 0.0
            # Cap on how much the trigram (gram) signal can contribute to a
            # field's text score. Kept below the matchCount unit (100) so a
            # trigram-only match can never outrank a single exact token match.
            query(gram_cap) double: 80.0
            # Per-observer rank floor for filter:rank:gte/gt. Defaults below
            # every real score so the gate in the rank_* profiles below is a
            # no-op unless a query sets it.
            query(min_rank) double: -1000000000.0
            # Match-quality ladder step (§10): spacing between the
            # exact>prefix>1-typo>2-typo tiers within the token-match band.
            query(w_match_step) double: 250.0
            # Multi-word proximity bonus (fieldMatch). Tie-breaker WITHIN a
            # match-quality tier; < w_match_step so it never reorders tiers.
            query(w_proximity) double: 30.0
            # Popularity/trust profiles: the exact>typo match tier sits ABOVE
            # the trust sort so a genuine name match never loses to a
            # more-popular typo/substring hit.
            query(w_pop_token_tier) double: 1000000000.0
            query(w_pop_match_step) double: 10000000.0
            # Affiliation tier (§11): a genuine bio OR website-domain token
            # match ranks above gram noise, below real name matches.
            query(w_affil_tier) double: 10000000.0
            query(w_affil_tier_text) double: 550.0
            # Default (sort_followers) §12 rewrite: IDF-diluted text ×
            # modest multiplicative trust.
            query(w_name_tier) double: 2000.0
            query(w_identity) double: 50.0
            query(w_wot) double: 1.0
            # Discard hits whose text_score is below this BEFORE the trust
            # multiply — kills weak gram-only noise so trust can't float it.
            query(text_score_cutoff) double: 50.0
            # Tier-group weights (generic-tier extension, non-profile kinds).
            query(w_secondary) double: 0.4
            query(w_content) double: 0.15
            query(w_location) double: 0.3
        }

        # The observer's trust in this doc's AUTHOR, via the reputation parent.
        function user_score() {
            expression: sum(query(user_q) * attribute(author_influence_scores))
        }

        function verified_followers() {
            expression: sum(query(user_q) * attribute(author_follower_counts))
        }

        # Text relevance for the name field — the primary signal.
        # Guard the bm25/fieldLength division against fieldLength=0 (empty
        # field): 0/0 = NaN would propagate through max() in primary_text.
        function name_text() {
            expression {
                matchCount(name) * 100
                + if(fieldLength(name) > 0, bm25(name) / pow(fieldLength(name), 1.5), 0)
                + min(query(w_gram) * bm25(name_gram), query(gram_cap))
            }
        }

        function display_name_text() {
            expression {
                matchCount(display_name) * 100
                + if(fieldLength(display_name) > 0, bm25(display_name) / pow(fieldLength(display_name), 1.5), 0)
                + min(query(w_gram) * bm25(display_name_gram), query(gram_cap))
            }
        }

        # about: IDF-aware only (bm25), no flat matchCount term — rare bio
        # terms find affiliated people, common words don't surface
        # bio-mentioners over name-bearers.
        function about_text() {
            expression {
                bm25(about)
                + query(w_gram) * bm25(about_gram)
            }
        }

        # name and display_name have EQUAL impact: max, not sum, so the same
        # term isn't double-counted across both fields.
        function primary_text() {
            expression: max(name_text(), display_name_text())
        }

        # about contributes only when NOTHING primary matched (fallback).
        function secondary_active() {
            expression: if(has_token_match() > 0, 0, 1)
        }

        # A "real" token match — exact/prefix/fuzzy in an INDEXED name or
        # identity field; trigram-only recall doesn't feed matchCount.
        function has_token_match() {
            expression: if(matchCount(name) > 0 || matchCount(display_name) > 0 || matchCount(nip05) > 0 || matchCount(lud16) > 0, 1, 0)
        }

        # Graded match quality from the labeled query clauses (vespa_query.py
        # _field_clauses): 4=exact, 3=prefix, 2=1-typo, 1=2-typo, 0=gram-only.
        # KNOWN-INERT: itemRawScore does not populate for plain text terms
        # (Brainstorm staging, 2026-06-30) — degrades safely to 0; the coarse
        # has_token_match tier still applies. Kept for the day Vespa populates
        # term raw scores or the verbatim-field rework (§11.1) lands.
        function match_quality() {
            expression: if(itemRawScore(mtch_exact) > 0, 4, if(itemRawScore(mtch_prefix) > 0, 3, if(itemRawScore(mtch_fz1) > 0, 2, if(itemRawScore(mtch_fz2) > 0, 1, 0))))
        }

        # A bio/website affiliation match WITHOUT any name-field token match.
        function affiliation_match() {
            expression: if(has_token_match() > 0, 0, if(matchCount(about) > 0 || matchCount(website) > 0, 1, 0))
        }

        # Multi-word proximity over the primary fields (0..1): Meilisearch's
        # `proximity` rule. ~1 for single-word queries (harmless); rewards
        # close-together terms on multi-word ones. Tier fields included so
        # titles get the same treatment (generic-tier extension).
        function proximity() {
            expression: max(max(fieldMatch(name).proximity, fieldMatch(display_name).proximity), fieldMatch(search_primary).proximity)
        }

        # Genuine NAME token match (name/display_name only) — nip05/lud16
        # deliberately excluded; they score via identity_text (IDF) so a
        # common domain like primal.net can't flood the name tier.
        function name_match() {
            expression: if(matchCount(name) > 0 || matchCount(display_name) > 0, 1, 0)
        }

        # IDF-aware identity handles: bm25 is tf*IDF, so a token shared by
        # thousands of nip05s (primal, gmail, com) scores ~0 while a unique
        # handle scores high — "the more a word is used, the smaller the score".
        function identity_text() {
            expression: bm25(nip05) + bm25(lud16)
        }

        function identity_match() {
            expression: if(matchCount(nip05) > 0 || matchCount(lud16) > 0, 1, 0)
        }

        # ---- generic-tier extension: the generic tier group (non-profile kinds). ----
        # Same shape as the name math so magnitudes stay cross-kind
        # comparable: an exact title/subject token match ~ an exact name match.
        # All of these are 0 on kind-0 docs (their tier fields are empty),
        # exactly as the profile functions are 0 on non-profile docs — which is
        # why composition below is a plain sum, never an if(kind) dispatch.

        function tier_token_match() {
            expression: if(matchCount(search_primary) > 0, 1, 0)
        }

        function tier_primary_text() {
            expression {
                matchCount(search_primary) * 100
                + if(fieldLength(search_primary) > 0, bm25(search_primary) / pow(fieldLength(search_primary), 1.5), 0)
                + min(query(w_gram) * bm25(search_primary_gram), query(gram_cap))
            }
        }

        # Secondary tier text: bm25 plus its discriminative gram net — the same
        # typo-recall treatment about_text() gives bios, extended to every kind's
        # summary/description. Uncapped, exactly like about_text().
        function secondary_text() {
            expression {
                bm25(search_secondary)
                + query(w_gram) * bm25(search_secondary_gram)
            }
        }

        function tier_text() {
            expression {
                tier_token_match() * query(w_name_tier)
                + tier_primary_text()
                + query(w_secondary) * secondary_text()
                + query(w_content) * bm25(search_text)
                + query(w_location) * bm25(search_location)
            }
        }

        # ---- composites (profile group + tier group; disjoint per kind) ----

        function any_token_match() {
            expression: max(has_token_match(), tier_token_match())
        }

        # IDF-diluted TEXT score for the default profile — the thing that gets
        # MULTIPLIED by trust. All terms are text; common tokens and gram-only
        # noise stay low so trust can't float them. (Brainstorm text_score()
        # + the tier group.)
        function text_score() {
            expression {
                name_match() * query(w_name_tier)
                + primary_text()
                + query(w_identity) * identity_text()
                + affiliation_match() * query(w_affil_tier_text)
                + secondary_active() * query(w_about) * about_text()
                + tier_text()
            }
        }

        # MULTIPLICATIVE trust — NOT additive (additive WoT swamped exactness).
        # 0 below the rank cutoff (server passes min_rank=2), then a modest
        # CONCAVE (log, diminishing-returns) boost. w_wot=0 => pure text.
        function wot_mult() {
            expression: if(user_score() < query(min_rank), 0.0, 1.0 + query(w_wot) * log(1.0 + max(0.0, user_score() - query(min_rank))))
        }

        # PURE-TEXT relevance (Brainstorm relevance() + the tier group):
        # token-match band on top, match-quality ladder + proximity within,
        # affiliation above gram noise, bm25 ordering inside each band.
        function relevance() {
            expression {
                any_token_match() * 1100
                + match_quality() * query(w_match_step)
                + affiliation_match() * query(w_affil_tier_text)
                + query(w_proximity) * proximity()
                + primary_text()
                + tier_primary_text()
                + query(w_secondary) * secondary_text()
                + query(w_content) * bm25(search_text)
                + query(w_location) * bm25(search_location)
                + secondary_active() * query(w_about) * about_text()
            }
        }

        first-phase {
            expression: relevance()
        }

        match-features {
            user_score
            name_text
            display_name_text
            about_text
            has_token_match
            match_quality
            affiliation_match
            itemRawScore(mtch_exact)
            itemRawScore(mtch_prefix)
            itemRawScore(mtch_fz1)
            itemRawScore(mtch_fz2)
            itemRawScore(mtch_affil)
        }
    }

    # -----------------------------------------------------------------------
    # Trust-sorted profiles. All inherit text_relevance (functions, inputs,
    # match-features carry over). Each gates on query(min_rank) by mapping a
    # failing hit to the SENTINEL (-1e9) and letting rank-score-drop-limit
    # (-1e6) drop it; real scores stay far above the sentinel.
    # -----------------------------------------------------------------------

    # filter:rank only (no sort): keep the pure-text order, drop low-trust.
    rank-profile rank_filtered inherits text_relevance {
        first-phase {
            expression: if(user_score() >= query(min_rank), relevance(), -1000000000.0)
            rank-score-drop-limit: -1000000.0
        }
    }

    # sort:rank:desc (+ optional filter): trust-sorted WITHIN each match tier —
    # token matches above gram noise, exact>typo bucketing above trust, trust
    # ordering inside a tier (Meilisearch's `typo` over `sort`).
    rank-profile rank_desc inherits text_relevance {
        first-phase {
            expression: if(user_score() >= query(min_rank), any_token_match() * query(w_pop_token_tier) + match_quality() * query(w_pop_match_step) + affiliation_match() * query(w_affil_tier) + user_score(), -1000000000.0)
            rank-score-drop-limit: -1000000.0
        }
    }

    # sort:rank:asc: ascending trust WITHIN each (still-descending) match tier.
    rank-profile rank_asc inherits text_relevance {
        first-phase {
            expression: if(user_score() >= query(min_rank), any_token_match() * query(w_pop_token_tier) + match_quality() * query(w_pop_match_step) + affiliation_match() * query(w_affil_tier) - user_score(), -1000000000.0)
            rank-score-drop-limit: -1000000.0
        }
    }

    # DEFAULT profile (Brainstorm §12, 2026-07-01): IDF-diluted text score
    # MULTIPLIED by the modest concave trust curve. Weak text (below
    # text_score_cutoff) and below-cutoff trust (wot_mult()=0) both map to 0
    # and are dropped. Tune LIVE via query(w_wot)/query(w_identity)/
    # query(min_rank)/query(w_name_tier) — rank-config, no redeploy.
    rank-profile sort_followers inherits text_relevance {
        first-phase {
            expression: if(text_score() < query(text_score_cutoff), 0.0, text_score() * wot_mult())
            rank-score-drop-limit: 0.5
        }

        # Surface the decisive signals so the API/inspector can show WHY a hit
        # ranked where it did (text bands + the trust multiplier).
        match-features {
            user_score
            verified_followers
            name_match
            identity_match
            identity_text
            has_token_match
            affiliation_match
            text_score
            wot_mult
            name_text
            display_name_text
            about_text
        }
    }

    # the library's stable profile names: `search` is what EventYql sends by default
    # for any search term (currently Brainstorm's §12 default), `text` is the
    # pure-text profile NIP-50 `sort:text` selects. Both are pure renames.
    rank-profile search inherits sort_followers {
    }

    rank-profile text inherits text_relevance {
    }

    # TWO-PHASE variant of `text` (A/B under measurement; see
    # docs/two-phase-ranking.html). Phase 1 scores every match with
    # relevance() MINUS its two expensive within-band tie-breakers —
    # fieldMatch proximity (a positional analysis per field per hit) and the
    # match-quality ladder (itemRawScore, currently inert anyway) — which
    # keeps BAND membership exact: the dropped terms (≤ ~280 points) can
    # never cross the 1100-point token-match band gap. Phase 2 re-applies the
    # full tuned relevance() to the top rerank-count hits per node, restoring
    # today's exact within-band order inside the window. Query-time override:
    # `ranking.rerankCount`.
    rank-profile text2 inherits text_relevance {
        function relevance_cheap() {
            expression {
                any_token_match() * 1100
                + affiliation_match() * query(w_affil_tier_text)
                + primary_text()
                + tier_primary_text()
                + query(w_secondary) * secondary_text()
                + query(w_content) * bm25(search_text)
                + query(w_location) * bm25(search_location)
                + secondary_active() * query(w_about) * about_text()
            }
        }

        first-phase {
            expression: relevance_cheap()
        }

        second-phase {
            expression: relevance()
            rerank-count: 1000
        }
    }
}
