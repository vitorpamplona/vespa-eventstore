# Per-pubkey ranking state — NOT an event. The scores projection derives it
# from stored kind-30382s (and their provider mapping) and keeps it current
# through the store's change feed; it is rebuildable from the event corpus at
# any time.
#
# Declared GLOBAL in services.xml so event documents can reference it
# (event.sd's author_ref) and import both tensors into their own ranking:
# one search over `event` ranks ANY kind by the observer's web of trust for
# the doc's author. Global documents replicate to every content node and are
# held in memory — fine at roster scale (10^5..10^6 pubkeys), a capacity
# decision to revisit before multi-node.
#
# Tensor shapes follow Brainstorm (brainstorm_server app/core/vespa.py):
#   influence_scores{observer}  = rank (influence*100, 0..100), int8
#   follower_counts{observer} = verified-follower count, float
schema profile {

    document profile {

        field pubkey type string {
            indexing: attribute | summary
            attribute: fast-search
        }

        field influence_scores type tensor<int8>(user{}) {
            indexing: attribute
        }

        field follower_counts type tensor<float>(user{}) {
            indexing: attribute
        }
    }
}
