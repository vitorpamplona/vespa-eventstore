<?xml version="1.0" encoding="UTF-8" ?>
<services version="1.0">

  <container id="default" version="1.0">
    <search />
    <document-api />
    <nodes>
      <node hostalias="node1" />
    </nodes>
  </container>

  <content id="content" version="1.0">
    <redundancy>1</redundancy>

    <documents>
      <document type="event" mode="index" />
      <!-- Ranking state per pubkey; GLOBAL so event docs can reference it and
           import the trust tensors into their own ranking (parent/child). -->
      <document type="profile" mode="index" global="true" />
    </documents>

    <nodes>
      <node distribution-key="0" hostalias="node1" />
    </nodes>

    <!-- Single-node dev tuning: Vespa blocks feeds at 80% disk / 85% memory
         by default, which thin-provisioned or small dev disks trip
         immediately (statvfs reports the host, not the workload). Raised for
         the local engine; a real multi-node deployment should size disks
         instead of leaning on this. -->
    <tuning>
      <resource-limits>
        <disk>0.985</disk>
        <memory>0.92</memory>
      </resource-limits>
    </tuning>

    <!-- Bulk ingest is the workload (a full trust-provider sync feeds
         millions of docs); let proton use every core for feeding. -->
    <config name="vespa.config.search.core.proton">
      <feeding>
        <concurrency>1.0</concurrency>
      </feeding>
      <!-- The transaction log is a durability journal that is pruned once its
           contents are flushed to the persisted index. Its default flush
           trigger (maxtlssize) is 20 GiB, and for small events the in-memory
           index never hits its own memory trigger first — so the translog was
           the dominant trigger and grew to ~19 GiB, filling the disk and
           feed-blocking the engine mid-sync. Cap it at 4 GiB so it flushes and
           prunes far sooner; the memory trigger stays default. -->
      <flush>
        <memory>
          <maxtlssize>4294967296</maxtlssize>
        </memory>
      </flush>
    </config>
  </content>

</services>
