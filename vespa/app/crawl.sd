# Per-pubkey CRAWL bookkeeping — how completely SoT has indexed this author's
# content. NOT an event, and NOT ranking state (that is profile.sd). Written
# ONLY by the sync side; the coverage report groups over it.
#
# Deliberately a SEPARATE, ordinary (on-disk, index-mode) document rather than
# fields on the global in-memory `profile` doc: it is write-heavy crawl churn
# that must not sit in RAM on every content node, and keeping it off `profile`
# means the trust projection's full-document rewrites can never clobber it.
#
# Every field is an attribute so the coverage groupings and the pass's
# "already synced" selection run in-memory without touching the disk store.
schema crawl {

    document crawl {

        field pubkey type string {
            indexing: attribute | summary
            attribute: fast-search
        }

        # Epoch seconds of the last CLEAN outbox reconcile (0 = never). A clean
        # reconcile means we pulled ALL of this author's content from one of
        # their write relays; a timed-out fetch does NOT stamp it. Drives the
        # synced/pending split, the refresh TTL, and the ETA rate.
        field content_synced_at type long {
            indexing: attribute
        }

        # Epoch seconds we last RESOLVED this author's outbox (0 = never looked).
        # Distinguishes "we looked and found no 10002" from "not looked yet", so
        # the no-outbox population is counted honestly during a load in progress.
        field outbox_checked_at type long {
            indexing: attribute
        }
    }
}
